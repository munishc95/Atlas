# Atlas API settings
ATLAS_DATABASE_URL=sqlite:///./apps/api/.atlas/atlas.db
ATLAS_DUCKDB_PATH=apps/api/.atlas/ohlcv.duckdb
ATLAS_PARQUET_ROOT=data/parquet
ATLAS_REDIS_URL=redis://localhost:6379/0
ATLAS_RQ_QUEUE_NAME=atlas
ATLAS_JOBS_INLINE=false
ATLAS_JOB_DEFAULT_TIMEOUT_SECONDS=10800
ATLAS_JOB_RETRY_MAX=2
ATLAS_JOB_RETRY_BACKOFF_SECONDS=5
ATLAS_RISK_PER_TRADE=0.005
ATLAS_MAX_POSITIONS=3
ATLAS_KILL_SWITCH_DRAWDOWN=0.08
ATLAS_KILL_SWITCH_COOLDOWN_DAYS=10
ATLAS_COMMISSION_BPS=5.0
ATLAS_SLIPPAGE_BASE_BPS=2.0
ATLAS_SLIPPAGE_VOL_FACTOR=15.0
ATLAS_MAX_POSITION_VALUE_PCT_ADV=0.01
ATLAS_DIVERSIFICATION_CORR_THRESHOLD=0.75
ATLAS_FOUR_HOUR_BARS=09:15-13:15,13:15-15:30
ATLAS_CRED_KEY=
ATLAS_CRED_KEY_PATH=data/secrets/atlas_cred.key
ATLAS_UPSTOX_CLIENT_ID=
ATLAS_UPSTOX_CLIENT_SECRET=
ATLAS_UPSTOX_REDIRECT_URI=http://localhost:3000/providers/upstox/callback
ATLAS_UPSTOX_PERSIST_ENV_FALLBACK=false
ATLAS_UPSTOX_E2E_FAKE_CODE=ATLAS_E2E_FAKE_CODE
ATLAS_UPSTOX_NOTIFIER_BASE_URL=http://127.0.0.1:8000
ATLAS_UPSTOX_NOTIFIER_SECRET=
ATLAS_UPSTOX_NOTIFIER_PENDING_NO_CALLBACK_MINUTES=15
ATLAS_UPSTOX_NOTIFIER_STALE_HOURS=72
ATLAS_UPSTOX_AUTO_RENEW_ENABLED=false
ATLAS_UPSTOX_AUTO_RENEW_TIME_IST=06:30
ATLAS_UPSTOX_AUTO_RENEW_IF_EXPIRES_WITHIN_HOURS=12
ATLAS_UPSTOX_AUTO_RENEW_ONLY_WHEN_PROVIDER_ENABLED=true
ATLAS_DATA_UPDATES_PROVIDER_NSE_BHAVCOPY_ENABLED=true
ATLAS_NSE_BHAVCOPY_BASE_URL=https://nsearchives.nseindia.com
ATLAS_NSE_BHAVCOPY_PATH_TEMPLATE=/products/content/sec_bhavdata_full_{DDMMYYYY}.csv
