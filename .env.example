ATLAS_NSE_BHAVCOPY_MAX_TRADING_DAYS_PER_CALL=90
ATLAS_NSE_BHAVCOPY_CACHE_DIR=data/cache/nse_bhavcopy
ATLAS_HISTORICAL_BACKFILL_MAX_TRADING_DAYS_PER_RUN=366
ATLAS_DATA_PROVENANCE_CONFIDENCE_NSE_BHAVCOPY=90
ATLAS_CONFIDENCE_GATE_ENABLED=true
ATLAS_CONFIDENCE_GATE_AVG_THRESHOLD=70
ATLAS_CONFIDENCE_GATE_LOW_SYMBOL_THRESHOLD=65
ATLAS_CONFIDENCE_GATE_LOW_PCT_THRESHOLD=0.50
ATLAS_CONFIDENCE_GATE_FALLBACK_PCT_THRESHOLD=0.80
ATLAS_CONFIDENCE_GATE_HARD_FLOOR=55
ATLAS_CONFIDENCE_GATE_ACTION_ON_TRIGGER=SHADOW_ONLY
